generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]
}

model User {
  id           String            @id @default(uuid())
  email        String            @unique
  passwordHash String
  firstName    String
  lastName     String
  roleId       Int
  createdAt    DateTime          @default(now())
  role         Role              @relation(fields: [roleId], references: [id])
  admin        Admin?
  incidents    Incident[]
  comments     IncidentComment[]
}

model Admin {
  id        Int      @id @default(autoincrement())
  userId    String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Priority {
  id         Int        @id @default(autoincrement())
  name       String     @unique
  categories Category[]
}

model Category {
  id         Int        @id @default(autoincrement())
  name       String     @unique
  priorityId Int
  priority   Priority   @relation(fields: [priorityId], references: [id])
  incidents  Incident[]
}

model Status {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  incidents Incident[]
}

model Incident {
  id            Int               @id @default(autoincrement())
  title         String
  description   String
  location      String
  categoryId    Int
  statusId      Int
  authorId      String
  createdAt     DateTime          @default(now())
  lastUpdatedAt DateTime          @default(now())
  category      Category          @relation(fields: [categoryId], references: [id])
  status        Status            @relation(fields: [statusId], references: [id])
  author        User              @relation(fields: [authorId], references: [id])
  comments      IncidentComment[]
  photos        IncidentPhoto[]
}

model IncidentComment {
  id         Int      @id @default(autoincrement())
  incidentId Int
  authorId   String
  content    String
  createdAt  DateTime @default(now())
  incident   Incident @relation(fields: [incidentId], references: [id])
  author     User     @relation(fields: [authorId], references: [id])
}

model IncidentPhoto {
  id         Int      @id @default(autoincrement())
  incidentId Int
  fileUrl    String
  uploadedAt DateTime @default(now())
  incident   Incident @relation(fields: [incidentId], references: [id])
}

model PumpingStation {
  id        Int    @id @default(autoincrement())
  name      String
  location  String
  pumps     Pump[]

  @@map("Pumping_stations")
}

model PumpModel {
  id    Int    @id @default(autoincrement())
  name  String
  pumps Pump[]

  @@map("Pump_models")
}

model PumpState {
  id    Int    @id @default(autoincrement())
  name  String
  pumps Pump[]

  @@map("Pump_states")
}

model Pump {
  id        Int             @id @default(autoincrement())
  stationId Int             @map("station_id")
  name      String
  modelId   Int             @map("model")
  stateId   Int             @map("state")

  station   PumpingStation  @relation(fields: [stationId], references: [id])
  model     PumpModel       @relation(fields: [modelId], references: [id])
  state     PumpState       @relation(fields: [stateId], references: [id])
  telemetry PumpTelemetry[]

  @@map("Pumps")
}

model PumpTelemetry {
  id           Int      @id @default(autoincrement())
  pumpId       Int      @map("pump_id")
  time         DateTime
  voltageV     Float    @map("voltage_v")
  currentA     Float    @map("current_a")
  vibrationRms Float    @map("vibration_rms")
  temperatureC Float    @map("temperature_c")
  pressureIn   Float    @map("pressure_in")
  pressureOut  Float    @map("pressure_out")

  pump         Pump     @relation(fields: [pumpId], references: [id])

  @@map("Pumps_telemetry")
}